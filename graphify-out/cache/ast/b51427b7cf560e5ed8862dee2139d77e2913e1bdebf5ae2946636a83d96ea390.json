Loader.ts", "source_location": "L42"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_resolveeffectiveurl", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L46"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_resolveeffectiveurl", "callee": "finally", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L49"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_resolveeffectiveurl", "callee": "(async () => {\n            // Check if we already have this in DB (e.g. imported media)\n            let dbItem = (await db.mediaPool.get(fileId) || await db.backgrounds.get(fileId)) as { data?: Blob, path?: string } | undefined;\n            \n            if (!dbItem) {\n                // Fallback 1: check by exact path match\n                const path = extractPathFromLocalResource(fileId) || fileId;\n                dbItem = await db.mediaPool.where('path').equals(path).first();\n                \n                if (!dbItem) {\n                    // Fallback 1.5: check backgrounds table by path\n                    dbItem = await db.backgrounds.where('path').equals(path).first();\n                }\n\n                if (!dbItem) {\n                    // Fallback 2: check by filename only (useful for presentations from other machines)\n                    const filename = path.split(/[/\\\\]/).pop();\n                    if (filename && filename.includes('.')) {\n                        dbItem = await db.mediaPool.where('name').equals(filename).first();\n                        \n                        // Final sanity check: try normalized name fallback\n                        if (!dbItem) {\n                            const normalized = filename.normalize('NFC');\n                            dbItem = await db.mediaPool.where('name').equals(normalized).first();\n                        }\n                    }\n                }\n            }\n\n            if (dbItem?.data) {\n                const blobUrl = URL.createObjectURL(dbItem.data);\n                \n                // LRU for Blob URLs to prevent memory leaks\n                if (this.blobUrlCache.size >= this.MAX_BLOB_CACHE) {\n                    const oldestKey = this.blobUrlCache.keys().next().value;\n                    if (oldestKey) {\n                        const oldUrl = this.blobUrlCache.get(oldestKey);\n                        if (oldUrl) URL.revokeObjectURL(oldUrl);\n                        this.blobUrlCache.delete(oldestKey);\n                    }\n                }\n                \n                this.blobUrlCache.set(fileId, blobUrl);\n                return blobUrl;\n            }\n\n            const dbPath = dbItem && 'path' in dbItem ? dbItem.path as string : undefined;\n            const pathToCheck = dbPath || extractPathFromLocalResource(fileId) || fileId;\n            return this.resolveUrl(pathToCheck);\n        })", "is_member_call": false, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L49"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_resolveeffectiveurl", "callee": "set", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L102"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L109"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "generateWaveformPoints", "is_member_call": false, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L122"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "next", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L126"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "keys", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L126"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "delete", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L127"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getwaveform", "callee": "set", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L129"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_loadaudio", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L139"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_loadaudio", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L143"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_loadaudio", "callee": "(async () => {\n            try {\n                // Metadata-first check BEFORE fetch\n                // We allow up to 300s (5 minutes) to be decoded into memory.\n                // This is needed for waveforms. Anything longer is discarded to save RAM.\n                const duration = await this.getDuration(url);\n                if (duration <= 0 || duration > 300) {\n                    return null;\n                }\n\n                const response = await fetch(resolvedUrl);\n                if (!response.ok) {\n                    return null;\n                }\n\n                const contentLength = response.headers.get('Content-Length');\n                if (contentLength && parseInt(contentLength) > 100 * 1024 * 1024) {\n                    return null;\n                }\n\n                const arrayBuffer = await response.arrayBuffer();\n\n                try {\n                    const audioBuffer = await ctx.decodeAudioData(arrayBuffer);\n                    \n                    // Update buffer LRU cache\n                    if (this.bufferCache.size >= this.MAX_BUFFER_CACHE) {\n                        const oldestKey = this.bufferCache.keys().next().value;\n                        if (oldestKey) this.bufferCache.delete(oldestKey);\n                    }\n                    this.bufferCache.set(resolvedUrl, audioBuffer);\n                    \n                    return audioBuffer;\n                } catch (e) {\n                    console.error('AudioBufferLoader: Decode error', e);\n                    return null;\n                }\n            } catch (error) {\n                return null;\n            } finally {\n                this.loadingPromises.delete(resolvedUrl);\n            }\n        })", "is_member_call": false, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L146"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_loadaudio", "callee": "set", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L190"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getfilestats", "callee": "await IpcService.invoke", "is_member_call": false, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L196"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "has", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L207"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L207"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "get", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L210"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "finally", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L213"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "(async () => {\n            // Size-based Fast Fail BEFORE media pipeline\n            // If file is > 50MB, assume it's long and avoid probing\n            const stats = await this.getFileStats(url);\n            if (!stats) {\n                return 0; // File is missing, don't even try to probe\n            }\n            if (stats.size > 50 * 1024 * 1024) {\n                return 301; // Fake \"long enough\" duration to trigger streaming\n            }\n\n            return new Promise<number>((resolve) => {\n                const tempAudio = new Audio(resolvedUrl);\n                tempAudio.onloadedmetadata = () => {\n                    const d = tempAudio.duration;\n                    tempAudio.src = '';\n                    tempAudio.load(); // Aggressive release\n                    this.durationCache.set(resolvedUrl, d);\n                    resolve(d);\n                };\n                tempAudio.onerror = () => {\n                    tempAudio.src = '';\n                    resolve(0);\n                };\n                // 5s timeout for probe to prevent hanging\n                setTimeout(() => {\n                    tempAudio.src = '';\n                    resolve(0);\n                }, 5000);\n            });\n        })", "is_member_call": false, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L213"}, {"caller_nid": "audio_audiobufferloader_audiobufferloader_getduration", "callee": "set", "is_member_call": true, "source_file": "/Users/borissmiyan/Work/AppDev/ekklesienter/src/features/presenter/utils/audio/AudioBufferLoader.ts", "source_location": "L247"}]}